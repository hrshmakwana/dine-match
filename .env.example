# ──────────────────────────────────────────────────────────────────────────────
# DineMatch — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Firebase (from Firebase Console → Project Settings → Your Apps → Web) ─────
EXPO_PUBLIC_FIREBASE_API_KEY=<EXPO_PUBLIC_FIREBASE_API_KEY>
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=<EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN>
EXPO_PUBLIC_FIREBASE_PROJECT_ID=<EXPO_PUBLIC_FIREBASE_PROJECT_ID>
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=<EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET>
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID>
EXPO_PUBLIC_FIREBASE_APP_ID=<EXPO_PUBLIC_FIREBASE_APP_ID>
EXPO_PUBLIC_FIREBASE_DATABASE_URL=<EXPO_PUBLIC_FIREBASE_DATABASE_URL>

# ── Google Maps & Places (from Google Cloud Console) ──────────────────────────
# Create two keys: one for iOS, one for Android (restrict each by platform)
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=<EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY>
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=<EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY>
EXPO_PUBLIC_GOOGLE_PLACES_KEY=<EXPO_PUBLIC_GOOGLE_PLACES_KEY>
# Used for nearby restaurant search

# ── EAS (Expo Application Services — for builds + OTA updates) ────────────────
# Get from: npx eas init
EAS_PROJECT_ID=<EAS_PROJECT_ID>

# ── App variant (set in CI/CD or locally for dev builds) ──────────────────────
# APP_VARIANT=development   # omit for production
